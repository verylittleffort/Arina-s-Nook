<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="apple-touch-icon" href="data:image/png;base64,">
  <link rel="icon" type="image/png" href="data:image/png;base64,">
  <title>Arina's Nook</title>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;600;700&family=Nunito:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --rose: #f4a0b0;
    --peach: #ffcba4;
    --lavender: #c9b8e8;
    --mint: #a8ddc5;
    --butter: #fde68a;
    --cream: #fff9f0;
    --warm-brown: #7a5c4e;
    --text: #4a3728;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body {
    font-family: 'Nunito', sans-serif;
    background: var(--cream);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }
  body::before {
    content:'';
    position:fixed; inset:0;
    background:
      radial-gradient(circle at 10% 20%, rgba(244,160,176,0.18) 0%, transparent 40%),
      radial-gradient(circle at 90% 10%, rgba(201,184,232,0.18) 0%, transparent 35%),
      radial-gradient(circle at 80% 80%, rgba(168,221,197,0.18) 0%, transparent 40%),
      radial-gradient(circle at 20% 85%, rgba(253,230,138,0.2) 0%, transparent 35%);
    pointer-events:none; z-index:0;
  }
  .floating-dots { position:fixed; inset:0; pointer-events:none; z-index:0; overflow:hidden; }
  .dot {
    position:absolute; border-radius:50%; opacity:0.35;
    animation: floatUp linear infinite;
  }
  @keyframes floatUp {
    0%   { transform:translateY(100vh) scale(0.5); opacity:0; }
    10%  { opacity:0.35; }
    90%  { opacity:0.35; }
    100% { transform:translateY(-10vh) scale(1); opacity:0; }
  }
  .app {
    position:relative; z-index:1;
    max-width:980px; margin:0 auto;
    padding:24px 20px 50px;
  }
  .header {
    text-align:center; margin-bottom:28px;
    animation: fadeDown 0.8s ease both;
  }
  .header h1 {
    font-family:'Caveat',cursive;
    font-size:clamp(2rem,6vw,3.2rem);
    color:var(--warm-brown); line-height:1.1;
  }
  .header p { font-size:1rem; color:#a07060; margin-top:6px; font-weight:300; }
  .heart-row { font-size:1.4rem; margin-bottom:6px; }
  @keyframes fadeDown {
    from { opacity:0; transform:translateY(-20px); }
    to   { opacity:1; transform:translateY(0); }
  }

  /* ── PHOTO SECTION ── */
  .photo-section {
    background:white; border-radius:28px; padding:20px;
    box-shadow:0 8px 32px rgba(122,92,78,0.12);
    margin-bottom:32px;
    animation: fadeUp 0.8s 0.15s ease both;
    position:relative; overflow:hidden;
  }
  .photo-section::before {
    content:''; position:absolute; inset:0;
    background:linear-gradient(135deg,rgba(244,160,176,0.05),rgba(201,184,232,0.05));
    border-radius:28px; pointer-events:none;
  }
  .photo-section-header {
    display:flex; align-items:center; justify-content:space-between;
    margin-bottom:14px; position:relative; z-index:1;
  }
  .photo-section-header h2 {
    font-family:'Caveat',cursive; font-size:1.5rem; color:var(--warm-brown);
  }
  .slideshow-toggle {
    font-size:0.82rem; font-family:'Nunito',sans-serif;
    background:rgba(244,160,176,0.15); color:#a07060;
    border:1px solid rgba(244,160,176,0.4);
    border-radius:12px; padding:6px 14px;
    cursor:pointer; transition:background 0.2s; font-weight:600;
  }
  .slideshow-toggle:hover, .slideshow-toggle.on { background:rgba(244,160,176,0.35); }

  .photo-frame {
    position:relative; border-radius:20px; overflow:hidden;
    background:linear-gradient(135deg,#f9e4ec,#e8d5f5);
    aspect-ratio:4/3;
  }
  .photo-slide {
    position:absolute; inset:0;
    opacity:0; transition:opacity 0.7s ease;
    display:flex; align-items:center; justify-content:center;
    pointer-events:none;
  }
  .photo-slide.active { opacity:1; pointer-events:auto; }
  .photo-slide img { width:100%; height:100%; object-fit:cover; }
  .photo-caption {
    position:absolute; bottom:0; left:0; right:0;
    background:linear-gradient(transparent,rgba(50,30,20,0.6));
    padding:28px 18px 14px;
  }
  .photo-caption p {
    color:white; font-family:'Caveat',cursive;
    font-size:1.35rem; text-shadow:0 1px 4px rgba(0,0,0,0.4);
  }
  .photo-nav {
    display:flex; align-items:center; justify-content:space-between;
    margin-top:12px; padding:0 4px;
  }
  .nav-arrow {
    background:none; border:none; cursor:pointer;
    font-size:1.4rem; padding:6px 12px; border-radius:50%;
    color:var(--warm-brown); transition:background 0.2s;
  }
  .nav-arrow:hover { background:rgba(244,160,176,0.2); }
  .photo-dots { display:flex; gap:7px; flex-wrap:wrap; justify-content:center; }
  .photo-dot {
    width:9px; height:9px; border-radius:50%;
    background:#e0c8c0; transition:all 0.3s; cursor:pointer;
  }
  .photo-dot.active { background:var(--rose); transform:scale(1.35); }
  .photo-counter { font-size:0.82rem; color:#a07060; font-weight:600; }

  /* ── TIMERS ── */
  .timers-header {
    display:flex; align-items:center; justify-content:space-between;
    margin-bottom:18px;
    animation: fadeUp 0.8s 0.25s ease both;
  }
  .timers-header h2 { font-family:'Caveat',cursive; font-size:1.9rem; color:var(--warm-brown); }
  .add-timer-btn {
    background:linear-gradient(135deg,var(--lavender),#b8a8d8);
    color:white; border:none; border-radius:20px;
    padding:10px 20px; font-family:'Nunito',sans-serif;
    font-size:0.9rem; font-weight:700; cursor:pointer;
    box-shadow:0 4px 12px rgba(201,184,232,0.45);
    transition:transform 0.2s, box-shadow 0.2s;
  }
  .add-timer-btn:hover { transform:translateY(-2px); box-shadow:0 6px 18px rgba(201,184,232,0.55); }

  .timers-grid {
    display:grid;
    grid-template-columns:repeat(auto-fill,minmax(260px,1fr));
    gap:18px;
  }

  /* Timer card */
  .timer-card {
    border-radius:24px; padding:22px;
    position:relative; overflow:hidden;
    box-shadow:0 6px 24px rgba(122,92,78,0.1);
    animation: popIn 0.4s cubic-bezier(0.34,1.56,0.64,1) both;
    transition:transform 0.2s, box-shadow 0.2s;
  }
  .timer-card:hover { transform:translateY(-3px); box-shadow:0 10px 30px rgba(122,92,78,0.15); }
  @keyframes popIn {
    from { opacity:0; transform:scale(0.75); }
    to   { opacity:1; transform:scale(1); }
  }
  .timer-card.theme-rose     { background:linear-gradient(135deg,#fff0f3,#ffe0e8); }
  .timer-card.theme-lavender { background:linear-gradient(135deg,#f4f0ff,#e8e0f8); }
  .timer-card.theme-mint     { background:linear-gradient(135deg,#f0fff8,#d8f5ea); }
  .timer-card.theme-peach    { background:linear-gradient(135deg,#fff5ee,#ffe8d0); }
  .timer-card.theme-butter   { background:linear-gradient(135deg,#fffbee,#fdf3c0); }

  .card-bg-emoji {
    position:absolute; top:-16px; right:-10px;
    font-size:5rem; opacity:0.1; pointer-events:none; line-height:1;
  }
  .timer-label-row {
    display:flex; align-items:center; justify-content:space-between;
    margin-bottom:12px;
  }
  .timer-label {
    font-family:'Caveat',cursive; font-size:1.25rem; font-weight:700;
    color:var(--warm-brown);
    background:none; border:none;
    border-bottom:2px dashed rgba(122,92,78,0.22);
    width:150px; cursor:text; outline:none; padding:2px 4px;
    transition:border-color 0.2s;
  }
  .timer-label:focus { border-bottom-color:var(--rose); }
  .delete-btn {
    background:none; border:none; cursor:pointer;
    font-size:1rem; opacity:0.35; transition:opacity 0.2s, transform 0.2s; padding:4px;
  }
  .delete-btn:hover { opacity:0.75; transform:scale(1.2); }

  /* Ring */
  .ring-wrap {
    display:flex; justify-content:center;
    position:relative; margin:6px 0 12px;
  }
  .timer-ring { transform:rotate(-90deg); }
  .ring-bg { fill:none; stroke:rgba(122,92,78,0.1); stroke-width:5; }
  .ring-fg { fill:none; stroke-width:5; stroke-linecap:round; transition:stroke-dashoffset 0.5s ease, stroke 0.3s; }
  .ring-label {
    position:absolute; inset:0;
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    font-family:'Caveat',cursive; color:var(--warm-brown); line-height:1.1;
  }
  .ring-time { font-size:1.75rem; font-weight:700; }
  .ring-status { font-size:0.8rem; opacity:0.6; }

  /* Inputs */
  .set-row {
    display:flex; align-items:center; gap:6px; justify-content:center;
    margin-bottom:14px;
  }
  .inp-wrap { display:flex; flex-direction:column; align-items:center; gap:2px; }
  .inp-wrap label { font-size:0.62rem; text-transform:uppercase; letter-spacing:1px; color:#a07060; font-weight:600; }
  .t-inp {
    width:52px; text-align:center;
    font-family:'Caveat',cursive; font-size:1.5rem; font-weight:700;
    color:var(--warm-brown);
    background:rgba(255,255,255,0.55);
    border:2px solid rgba(122,92,78,0.15);
    border-radius:10px; padding:4px 4px;
    outline:none; transition:border-color 0.2s;
  }
  .t-inp:focus { border-color:var(--rose); }
  .t-sep { font-size:1.5rem; font-weight:700; color:var(--warm-brown); margin-top:14px; }

  /* Controls */
  .ctrl-row { display:flex; gap:8px; }
  .ctrl-btn {
    flex:1; padding:9px; border:none; border-radius:14px;
    font-family:'Nunito',sans-serif; font-size:0.83rem; font-weight:700;
    cursor:pointer; transition:transform 0.15s, box-shadow 0.15s;
    display:flex; align-items:center; justify-content:center; gap:4px;
  }
  .ctrl-btn:hover  { transform:translateY(-2px); }
  .ctrl-btn:active { transform:scale(0.95); }
  .btn-start { background:linear-gradient(135deg,#a8ddc5,#7ec9a8); color:white; box-shadow:0 3px 10px rgba(168,221,197,0.5); }
  .btn-reset { background:linear-gradient(135deg,#e0d0f0,#c8b8e8); color:#5a4878; box-shadow:0 3px 10px rgba(201,184,232,0.4); }

  /* Done overlay */
  .done-overlay {
    position:absolute; inset:0; border-radius:24px;
    background:rgba(255,255,255,0.93);
    display:none; flex-direction:column;
    align-items:center; justify-content:center;
    gap:10px; z-index:10;
  }
  .done-overlay.show { display:flex; animation:fadeIn 0.3s ease; }
  .done-emoji { font-size:3rem; animation:wiggle 0.35s ease infinite alternate; }
  @keyframes wiggle {
    from { transform:rotate(-12deg) scale(1); }
    to   { transform:rotate(12deg)  scale(1.1); }
  }
  .done-text { font-family:'Caveat',cursive; font-size:1.8rem; color:var(--warm-brown); }
  .done-dismiss {
    background:linear-gradient(135deg,var(--rose),#e890a0);
    color:white; border:none; border-radius:14px;
    padding:8px 22px; font-family:'Nunito',sans-serif;
    font-size:0.85rem; font-weight:700; cursor:pointer;
    transition:transform 0.15s;
  }
  .done-dismiss:hover { transform:scale(1.05); }

  .footer {
    text-align:center; margin-top:44px;
    font-family:'Caveat',cursive; font-size:1.2rem; color:#c0a090;
    animation: fadeUp 0.8s 0.5s ease both;
  }

  @keyframes fadeUp  { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }
  @keyframes fadeIn  { from{opacity:0} to{opacity:1} }

  @media (max-width:500px) {
    .timers-grid { grid-template-columns:1fr; }
    .photo-frame { aspect-ratio:3/4; }
  }
</style>
</head>
<body>
<div class="floating-dots" id="dots"></div>
<div class="app">

  <div class="header">
    <div class="heart-row">💕✨🌸</div>
    <h1>A little something for you, my love</h1>
  </div>

  <!-- PHOTOS -->
  <div class="photo-section">
    <div class="photo-section-header">
      <h2>📷 Our Memories</h2>
      <button class="slideshow-toggle" id="ssBtn" onclick="toggleSlideshow()">▶ Slideshow</button>
    </div>
    <div class="photo-frame" id="photoFrame">
      <!-- slides injected by JS -->
    </div>
    <div class="photo-nav">
      <button class="nav-arrow" onclick="go(-1)">◀</button>
      <div style="display:flex;align-items:center;gap:14px;">
        <div class="photo-dots" id="photoDots"></div>
        <span class="photo-counter" id="photoCounter"></span>
      </div>
      <button class="nav-arrow" onclick="go(1)">▶</button>
    </div>
  </div>

  <!-- TIMERS -->
  <div class="timers-header">
    <h2>⏱️ Your Timers</h2>
    <button class="add-timer-btn" onclick="addTimer()">＋ New Timer</button>
  </div>
  <div class="timers-grid" id="timersGrid"></div>

  <div class="footer">Made for my Arina 💌</div>
</div>

<script>
const PHOTOS = [
  { caption: "Holding hands 🤍", src: "data:image/jpeg;base64," },
  { caption: "Sunset garden together 🌅", src: "data:image/jpeg;base64," },
  { caption: "Winter lights in Moscow ✨", src: "data:image/jpeg;base64," },
  { caption: "Snowy night out ❄️", src: "data:image/jpeg;base64," },
  { caption: "Hand in hand 🌿", src: "data:image/jpeg;base64," },
  { caption: "Streets of Japan 🇯🇵", src: "data:image/jpeg;base64," },
  { caption: "Train adventures 🚄", src: "data:image/jpeg;base64," },
  { caption: "City lights & you 💙", src: "data:image/jpeg;base64," },
  { caption: "Night with auntie 🌙", src: "data:image/jpeg;base64," },
];


// ── FLOATING DOTS ──
const dotsEl = document.getElementById('dots');
['#f4a0b0','#c9b8e8','#a8ddc5','#fde68a','#ffcba4'].forEach(c => {
  for(let i=0;i<4;i++){
    const d=document.createElement('div'); d.className='dot';
    const sz=Math.random()*14+6;
    d.style.cssText=`width:${sz}px;height:${sz}px;background:${c};left:${Math.random()*100}%;animation-duration:${Math.random()*16+12}s;animation-delay:-${Math.random()*20}s;`;
    dotsEl.appendChild(d);
  }
});

// ── PHOTOS ──
let cur=0, ssTimer=null, ssOn=false;

function buildPhotos(){
  const frame=document.getElementById('photoFrame');
  const dotsC=document.getElementById('photoDots');
  frame.innerHTML=''; dotsC.innerHTML='';
  PHOTOS.forEach((p,i)=>{
    const slide=document.createElement('div');
    slide.className='photo-slide'+(i===0?' active':'');
    slide.id='sl'+i;
    slide.innerHTML=`<img src="${p.src}" alt="Memory"><div class="photo-caption"><p>${p.caption}</p></div>`;
    frame.appendChild(slide);
    const dot=document.createElement('div');
    dot.className='photo-dot'+(i===0?' active':'');
    dot.onclick=()=>goTo(i);
    dotsC.appendChild(dot);
  });
  document.getElementById('photoCounter').textContent=`1 / ${PHOTOS.length}`;
}

function goTo(idx){
  document.querySelectorAll('.photo-slide').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.photo-dot').forEach(d=>d.classList.remove('active'));
  cur=(idx+PHOTOS.length)%PHOTOS.length;
  document.getElementById('sl'+cur).classList.add('active');
  document.querySelectorAll('.photo-dot')[cur].classList.add('active');
  document.getElementById('photoCounter').textContent=`${cur+1} / ${PHOTOS.length}`;
}
function go(d){ goTo(cur+d); }

function toggleSlideshow(){
  ssOn=!ssOn;
  const btn=document.getElementById('ssBtn');
  if(ssOn){
    btn.textContent='⏸ Slideshow'; btn.classList.add('on');
    ssTimer=setInterval(()=>go(1),3800);
  } else {
    btn.textContent='▶ Slideshow'; btn.classList.remove('on');
    clearInterval(ssTimer);
  }
}

buildPhotos();

// ── TIMERS ──
const THEMES=['theme-rose','theme-lavender','theme-mint','theme-peach','theme-butter'];
const STROKES=['#f4a0b0','#c9b8e8','#a8ddc5','#ffcba4','#f5d060'];
const EMOJIS=['🌸','🔮','🌿','🍑','✨'];
const CIRC=2*Math.PI*46;
let TC=0, timers={};

function addTimer(pre){
  const id=++TC;
  const ti=pre||{label:'My Timer',h:0,m:5,s:0};
  const th=(id-1)%THEMES.length;
  timers[id]={id,label:ti.label,h:ti.h,m:ti.m,s:ti.s,
    total:ti.h*3600+ti.m*60+ti.s,
    rem:ti.h*3600+ti.m*60+ti.s,
    running:false,done:false,th,iv:null};
  renderCard(id);
}

function renderCard(id){
  const t=timers[id];
  const grid=document.getElementById('timersGrid');
  const old=document.getElementById('tc'+id); if(old)old.remove();
  const c=document.createElement('div');
  c.className=`timer-card ${THEMES[t.th]}`; c.id='tc'+id;
  c.innerHTML=`
    <div class="card-bg-emoji">${EMOJIS[t.th]}</div>
    <div class="timer-label-row">
      <input class="timer-label" value="${t.label}" maxlength="18" oninput="timers[${id}].label=this.value">
      <button class="delete-btn" onclick="delTimer(${id})">✕</button>
    </div>
    <div class="ring-wrap">
      <svg class="timer-ring" width="120" height="120" viewBox="0 0 100 100">
        <circle class="ring-bg" cx="50" cy="50" r="46"/>
        <circle class="ring-fg" id="rf${id}" cx="50" cy="50" r="46"
          stroke="${STROKES[t.th]}"
          stroke-dasharray="${CIRC}" stroke-dashoffset="0"/>
      </svg>
      <div class="ring-label">
        <span class="ring-time" id="rt${id}">${fmt(t.rem)}</span>
        <span class="ring-status" id="rs${id}">ready</span>
      </div>
    </div>
    <div class="set-row" id="sr${id}">
      <div class="inp-wrap"><label>hrs</label>
        <input class="t-inp" id="ih${id}" type="number" min="0" max="23" value="${pad(t.h)}" onchange="setTime(${id})"></div>
      <span class="t-sep">:</span>
      <div class="inp-wrap"><label>min</label>
        <input class="t-inp" id="im${id}" type="number" min="0" max="59" value="${pad(t.m)}" onchange="setTime(${id})"></div>
      <span class="t-sep">:</span>
      <div class="inp-wrap"><label>sec</label>
        <input class="t-inp" id="is${id}" type="number" min="0" max="59" value="${pad(t.s)}" onchange="setTime(${id})"></div>
    </div>
    <div class="ctrl-row">
      <button class="ctrl-btn btn-start" id="sb${id}" onclick="startPause(${id})">▶ Start</button>
      <button class="ctrl-btn btn-reset" onclick="resetT(${id})">↺ Reset</button>
    </div>
    <div class="done-overlay" id="do${id}">
      <div class="done-emoji">🎉</div>
      <div class="done-text">Timer done!</div>
      <button class="done-dismiss" onclick="dismissDone(${id})">Yay! ✨</button>
    </div>`;
  grid.appendChild(c);
  updRing(id);
}

function pad(n){return String(n).padStart(2,'0');}
function fmt(s){
  const h=Math.floor(s/3600),m=Math.floor((s%3600)/60),sc=s%60;
  return h>0?`${pad(h)}:${pad(m)}:${pad(sc)}`:`${pad(m)}:${pad(sc)}`;
}
function updRing(id){
  const t=timers[id];
  const rf=document.getElementById('rf'+id); if(!rf)return;
  const frac=t.total>0?t.rem/t.total:1;
  rf.style.strokeDashoffset=CIRC*(1-frac);
  rf.style.stroke=t.rem<=10&&t.rem>0?'#e05050':STROKES[t.th];
}
function setTime(id){
  const t=timers[id];
  t.h=parseInt(document.getElementById('ih'+id).value)||0;
  t.m=parseInt(document.getElementById('im'+id).value)||0;
  t.s=parseInt(document.getElementById('is'+id).value)||0;
  t.total=t.h*3600+t.m*60+t.s; t.rem=t.total;
  document.getElementById('rt'+id).textContent=fmt(t.rem);
  updRing(id);
}
function startPause(id){
  const t=timers[id];
  if(t.done){resetT(id);return;}
  if(t.running){
    t.running=false; clearInterval(t.iv);
    document.getElementById('sb'+id).textContent='▶ Resume';
    document.getElementById('rs'+id).textContent='paused';
    return;
  }
  if(t.rem===0){resetT(id);return;}
  t.running=true;
  document.getElementById('sb'+id).textContent='⏸ Pause';
  document.getElementById('rs'+id).textContent='running';
  document.getElementById('sr'+id).style.opacity='0.4';
  document.getElementById('sr'+id).style.pointerEvents='none';
  t.iv=setInterval(()=>{
    t.rem--;
    document.getElementById('rt'+id).textContent=fmt(t.rem);
    updRing(id);
    if(t.rem<=0){
      clearInterval(t.iv); t.running=false; t.done=true;
      document.getElementById('rs'+id).textContent='done!';
      document.getElementById('do'+id).classList.add('show');
    }
  },1000);
}
function resetT(id){
  const t=timers[id]; clearInterval(t.iv);
  t.running=false; t.done=false; t.rem=t.total;
  document.getElementById('rt'+id).textContent=fmt(t.rem);
  document.getElementById('sb'+id).textContent='▶ Start';
  document.getElementById('rs'+id).textContent='ready';
  document.getElementById('sr'+id).style.opacity='1';
  document.getElementById('sr'+id).style.pointerEvents='';
  document.getElementById('do'+id).classList.remove('show');
  updRing(id);
}
function dismissDone(id){ document.getElementById('do'+id).classList.remove('show'); resetT(id); }
function delTimer(id){
  const t=timers[id]; if(t&&t.iv)clearInterval(t.iv); delete timers[id];
  const el=document.getElementById('tc'+id);
  if(el){el.style.transition='transform 0.3s,opacity 0.3s';el.style.transform='scale(0.8)';el.style.opacity='0';setTimeout(()=>el.remove(),300);}
}

